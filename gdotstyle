#!/usr/bin/env python3
#JG code

import re
import os
import subprocess
import sys

hex_pattern = re.compile(r"^[0-9a-fA-F]{6}$")

color = input("Enter hex color code: ").strip().strip('#')

if not hex_pattern.match(color):
    print("Invalid HEX code!")
    sys.exit(1)

final_color = f"#{color}"

waybar_path = os.path.expanduser("~/.dotfiles/waybar/themes/white.css")

with open(waybar_path, "r") as file:
    waybar_content = file.read()

waybar_content = re.sub(r"@define-color foreground [^;]+;", f"@define-color foreground {final_color};", waybar_content)
waybar_content = re.sub(r"@define-color mainfg [^;]+;", f"@define-color mainfg {final_color};", waybar_content)

with open(waybar_path, "w") as file:
    file.write(waybar_content)

sway_path = os.path.expanduser("~/.dotfiles/sway/themes/white")

with open(sway_path, "r") as file:
    sway_content = file.read()

sway_content = re.sub(r'set\s+\$accent\s+"[^"]+"', f'set $accent "{final_color}"', sway_content)

with open(sway_path, "w") as file:
    file.write(sway_content)

try:
    subprocess.run(["killall", "-SIGUSR2", "waybar"], stderr=subprocess.DEVNULL)
except Exception:
    pass

subprocess.run(["swaymsg", "reload"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

print("Done")
